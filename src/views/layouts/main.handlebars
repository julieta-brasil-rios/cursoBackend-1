<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Coder Backend</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      background-color: #f4f6f8;
      margin: 0;
      padding: 0;
    }

    header {
      background-color: #1e1e2f;
      color: white;
      padding: 15px 30px;
      font-size: 20px;
      font-weight: bold;
    }

    main {
      padding: 30px;
    }

    h1 {
      margin-bottom: 20px;
    }

    .products {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 20px;
    }

    .card {
      background: white;
      border-radius: 10px;
      padding: 20px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.05);
      transition: transform 0.2s ease;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    .price {
      font-weight: bold;
      margin-top: 10px;
      color: #2c7a7b;
    }

    button {
      margin-top: 10px;
      padding: 8px 12px;
      border: none;
      border-radius: 5px;
      cursor: pointer;
      font-weight: bold;
    }

    .btn-add {
      background-color: #2c7a7b;
      color: white;
    }

    .btn-delete {
      background-color: #e53e3e;
      color: white;
    }

    input {
      padding: 8px;
      margin-right: 10px;
      border-radius: 5px;
      border: 1px solid #ccc;
    }

    .form-container {
      margin-top: 30px;
      padding: 20px;
      background: white;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }
  </style>
</head>

<body>
  <header>
    💻 Coder Backend - Productos
  </header>

  <main>
    {{{body}}}
  </main>
</body>
</html>